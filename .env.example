# GitLab
GITLAB_TOKEN="your-gitlab-personal-access-token"
GITLAB_URL="https://gitlabru.domain.com"
GITLAB_PROJECT="group/project-name"

# Microsoft Teams
TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/..."

# Default polling interval in seconds; can be overridden per rule
POLL_INTERVAL_SECONDS=300

# Default email recipients if not set in a rule
DEFAULT_EMAIL=""

# SMTP (optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Jira (used by queue / compare / reports)
JIRA_URL="https://jira.domain.com"
JIRA_PROJECT="JIRAPROJECT"
JIRA_TOKEN=""

# Code Review (LLM) - OpenAI-compatible API
REVIEW_API_URL=https://api.openai.com/v1/chat/completions
REVIEW_API_KEY=
REVIEW_MODEL=gpt-4o
REVIEW_MAX_DIFF_CHARS=60000
REVIEW_BATCH_MAX_CHARS=20000
REVIEW_LLM_READ_TIMEOUT=120
REVIEW_LLM_MAX_ATTEMPTS=5
REVIEW_LLM_MAX_RETRY_DELAY=60

# Example for local Ollama + qwen2.5-coder:14b
# REVIEW_API_URL=http://127.0.0.1:11434/v1/chat/completions
# REVIEW_API_KEY=
# REVIEW_MODEL=qwen2.5-coder:14b
# REVIEW_MAX_DIFF_CHARS=30000
# REVIEW_BATCH_MAX_CHARS=12000
# REVIEW_LLM_READ_TIMEOUT=180

# REVIEW_API_URL=http://127.0.0.1:11434/v1/chat/completions
# REVIEW_API_KEY=
# REVIEW_MODEL=qwen2.5-coder:14b
# REVIEW_MAX_DIFF_CHARS=40000
# REVIEW_BATCH_MAX_CHARS=16000
# REVIEW_LLM_READ_TIMEOUT=240

# Server
HOST=0.0.0.0
PORT=8055
