# GitLab
GITLAB_TOKEN="your-gitlab-personal-access-token"
GITLAB_URL="https://gitlabru.domain.com"
GITLAB_PROJECT="group/project-name"

# Microsoft Teams
TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/..."

# Интервал опроса по умолчанию (секунды), можно переопределить в каждом правиле
POLL_INTERVAL_SECONDS=300

# Email-получатели по умолчанию (если не указаны в правиле), через запятую
DEFAULT_EMAIL=""

# SMTP (опционально)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Jira (для поиска MR по задачам)
JIRA_URL="https://jira.domain.com"
JIRA_PROJECT="JIRAPROJECT"

# Сервер
HOST=0.0.0.0
PORT=8055
